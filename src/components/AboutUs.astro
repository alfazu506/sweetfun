---
// src/components/AboutUs.astro
---
<section class="max-w-7xl mx-auto px-6 py-24">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    
    <!-- Images column -->
    <div class="relative min-h-[500px] w-full max-w-lg mx-auto lg:mx-0 hidden md:block">
      <!-- Main Image -->
      <div class="absolute inset-0 right-12 bottom-12 rounded-[3.5rem] overflow-hidden shadow-xl">
        <img 
          src="https://images.unsplash.com/photo-1550617931-e17a7b70dce2?q=80&w=1400&auto=format&fit=crop" 
          alt="Decorando galletas con glaseado" 
          class="w-full h-full object-cover"
        />
      </div>
      <!-- Secondary Overlapping Image -->
      <div class="absolute bottom-0 right-0 w-64 h-64 rounded-[3.5rem] overflow-hidden border-8 border-white shadow-2xl bg-gray-100">
        <img 
          src="https://images.unsplash.com/photo-1578985545062-69928b1d9587?q=80&w=800&auto=format&fit=crop" 
          alt="Pastel artesanal" 
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <!-- Mobile Image Layout (simplified) -->
	  <div class="md:hidden w-full h-72 rounded-[3.5rem] overflow-hidden shadow-lg mb-4">
      <img src="https://images.unsplash.com/photo-1550617931-e17a7b70dce2?q=80&w=1400&auto=format&fit=crop" alt="Decorando galletas" class="w-full h-full object-cover" />
    </div>

    <!-- Content column -->
    <div class="flex flex-col gap-10">
      
      <div class="space-y-6">
        <span class="text-vibrant-pink font-extrabold text-sm tracking-[0.2em] uppercase">
          Nuestra Historia
        </span>
        <h2 class="text-4xl md:text-6xl font-extrabold text-magazine-text leading-[1.1] tracking-tight">
          Hecho con amor <br class="hidden md:block" />
          y a tu medida
        </h2>
        <p class="text-magazine-text/70 text-lg md:text-xl leading-relaxed max-w-[42rem] font-medium">
          SweetFun es una pastelería artesanal donde cada pedido es único. Me especializo en crear momentos dulces e inolvidables. Al ser un proyecto personal, cuido cada detalle desde el batido hasta el último trazo de glaseado.
        </p>
      </div>

      <!-- Feature Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-2">
        
        <!-- Card 1 -->
        <div class="bg-pastel-pink rounded-[2rem] p-8 lg:p-10 transition-transform hover:-translate-y-1 duration-300">
          <div class="bg-white w-16 h-16 rounded-2xl flex items-center justify-center mb-8 shadow-sm">
            <span class="material-symbols-outlined text-vibrant-pink text-3xl">
              palette
            </span>
          </div>
          <h3 class="text-xl font-bold text-magazine-text mb-3">
            100% Personalizado
          </h3>
          <p class="text-magazine-text/70 text-sm leading-relaxed font-medium">
            Diseños únicos basados en tus personajes favoritos.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="bg-pastel-blue rounded-[2rem] p-8 lg:p-10 transition-transform hover:-translate-y-1 duration-300">
          <div class="bg-white w-16 h-16 rounded-2xl flex items-center justify-center mb-8 shadow-sm">
            <span class="material-symbols-outlined text-vibrant-blue text-3xl" style="font-variation-settings: 'FILL' 1;">
              volunteer_activism
            </span>
          </div>
          <h3 class="text-xl font-bold text-magazine-text mb-3">
            Toque Artesanal
          </h3>
          <p class="text-magazine-text/70 text-sm leading-relaxed font-medium">
            Cada pieza es decorada a mano con paciencia y detalle.
          </p>
        </div>

      </div>

    </div>
  </div>
</section>
