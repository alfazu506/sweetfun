---
import { Image } from "astro:assets";
import heroImage from "../assets/hero-image.png";
import WhatsappIcon from "./WhatsappIcon.astro";
---

<section
    class="relative overflow-hidden bg-gradient-to-br from-pastel-pink to-white py-12 md:py-24"
    aria-labelledby="hero-heading"
>
    <div
        class="container mx-auto px-6 lg:px-12 flex flex-col lg:flex-row items-center gap-12 lg:gap-20"
    >
        <!-- Left Column: Text Content -->
        <div class="flex-1 text-center lg:text-left z-10">
            <!-- Badge -->
            <div
                class="inline-block px-4 py-1.5 mb-6 rounded-full border border-pink-100 bg-white shadow-sm"
            >
                <span
                    class="text-xs font-bold tracking-widest text-vibrant-pink uppercase"
                >
                    Repostería Creativa & Artesanal
                </span>
            </div>

            <!-- Main Heading -->
            <h1
                id="hero-heading"
                class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-magazine-text leading-tight mb-6 tracking-tight"
            >
                Dulzura que <br class="hidden md:block" />
                <span class="text-vibrant-pink italic">divierte</span> en <br
                    class="hidden md:block"
                />
                cada bocado
            </h1>

            <!-- Description -->
            <p
                class="text-lg md:text-xl text-gray-600 mb-10 max-w-2xl mx-auto lg:mx-0 leading-relaxed font-medium"
            >
                Creamos momentos mágicos con pasteles y galletas personalizadas.
                Hechos con amor, dedicación y ese toque divertido que tus
                celebraciones merecen.
            </p>

            <!-- CTA Buttons -->
            <div
                class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4"
            >
                <a
                    href="#"
                    class="flex items-center justify-center gap-2 w-full sm:w-auto px-8 py-4 bg-vibrant-pink hover:bg-pink-600 text-white font-bold rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-vibrant-pink"
                    aria-label="Pedir por WhatsApp"
                >
                    <WhatsappIcon class="w-6 h-6 fill-current" />
                    ¡Pide el tuyo por WhatsApp!
                </a>
                <a
                    href="#"
                    class="flex items-center justify-center w-full sm:w-auto px-8 py-4 bg-pastel-blue hover:bg-blue-100 text-vibrant-blue font-bold rounded-2xl transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-vibrant-blue"
                >
                    Ver Galería
                </a>
            </div>
        </div>

        <!-- Right Column: Image and Floating Badge -->
        <div
            class="flex-1 relative w-full max-w-xl lg:max-w-none mx-auto mt-8 lg:mt-0 z-10"
        >
            <!-- Decorative Background Blur -->
            <div
                class="absolute inset-0 bg-gradient-to-tr from-vibrant-pink/20 to-vibrant-yellow/20 rounded-[3rem] blur-3xl transform scale-105 z-0"
            >
            </div>

            <!-- Main Image -->
            <div
                class="relative z-10 rounded-[3rem] overflow-hidden shadow-2xl border-4 border-white"
            >
                <Image
                    src={heroImage}
                    alt="Pastel de capas con flores y galletas decoradas con glaseado azul claro"
                    class="w-full h-auto object-cover aspect-[4/3]"
                    width={800}
                    height={600}
                />
            </div>
        </div>
    </div>
</section>

<style>
    /* Custom animation for the floating badge */
    @keyframes bounce-slow {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-10px);
        }
    }
    .animate-bounce-slow {
        animation: bounce-slow 4s ease-in-out infinite;
    }
</style>
