---
import { Image } from "astro:assets";
import logoImage from "../assets/logo.png";
import WhatsappIcon from "./WhatsappIcon.astro";

const currentYear = new Date().getFullYear();
---

<footer class="bg-pastel-blue py-12 md:py-16 mt-auto">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
      {/* Left Column – Brand */}
      <div class="flex flex-col space-y-6">
        <div class="flex items-center space-x-3">
          <Image
            src={logoImage}
            alt="SweetFun Logo"
            class="h-10 w-auto object-contain rounded-sm"
            width={100}
            height={48}
          />
          <span class="text-xl font-bold tracking-tight text-magazine-text"
            >SweetFun</span
          >
        </div>

        <p class="text-gray-500 text-sm md:text-base max-w-sm leading-relaxed">
          Endulzando tus momentos especiales con creatividad y sabor. Pastelería
          100% personalizada por encargo.
        </p>

        <div class="flex space-x-4 pt-2">
          {/* Instagram */}
          <a
            href="#"
            class="w-10 h-10 rounded-xl bg-pastel-pink flex items-center justify-center text-vibrant-pink hover:bg-pink-100 transition-colors focus:outline-none focus:ring-2 focus:ring-vibrant-pink"
            aria-label="Instagram"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          {/* Facebook */}
          <a
            href="#"
            class="w-10 h-10 rounded-xl bg-pastel-blue flex items-center justify-center text-vibrant-blue hover:bg-blue-100 transition-colors focus:outline-none focus:ring-2 focus:ring-vibrant-blue"
            aria-label="Facebook"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"
              ></path>
            </svg>
          </a>
        </div>

        {/* Contact Info */}
        <div class="flex flex-col space-y-2 pt-2">
          <a
            href="tel:+528001234567"
            class="inline-flex items-center text-sm text-gray-500 hover:text-vibrant-pink transition-colors group"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 mr-2 text-vibrant-pink/70 group-hover:text-vibrant-pink transition-colors"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            +52 800 123 4567
          </a>
          <a
            href="mailto:hola@sweetfun.mx"
            class="inline-flex items-center text-sm text-gray-500 hover:text-vibrant-pink transition-colors group"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 mr-2 text-vibrant-pink/70 group-hover:text-vibrant-pink transition-colors"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            hola@sweetfun.mx
          </a>
        </div>
      </div>

      {/* Right Column – Event Card */}
      <div
        class="bg-gradient-to-br from-pastel-yellow to-white/50 rounded-3xl p-6 md:p-8 lg:p-10 flex flex-col items-start space-y-4"
      >
        <h3
          class="text-2xl md:text-3xl font-extrabold text-magazine-text tracking-tight"
        >
          ¿Tienes un evento?
        </h3>
        <p class="text-gray-600 text-sm md:text-base max-w-md">
          Reserva tu fecha con anticipación para asegurar tu pastel
          personalizado.
        </p>
        <div class="pt-4">
          <a
            href="#"
            class="inline-flex items-center justify-center w-fit whitespace-nowrap px-5 py-3 text-sm lg:text-base font-bold text-white bg-vibrant-pink rounded-full hover:bg-pink-600 transition-colors shadow-md hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-vibrant-pink"
            aria-label="Contáctanos por WhatsApp"
          >
            <WhatsappIcon class="w-5 h-5 mr-2" />
            Contáctanos por WhatsApp
          </a>
        </div>
      </div>
    </div>

    {/* Bottom Bar */}
    <div
      class="mt-12 md:mt-16 pt-8 border-t border-gray-100 flex flex-col-reverse md:flex-row md:items-center justify-between gap-4"
    >
      <p class="text-xs font-semibold tracking-widest text-gray-400 uppercase">
        © {currentYear} SWEETFUN. HECHO CON AMOR POR UNA REPOSTERA APASIONADA.
      </p>
    </div>
  </div>
</footer>
